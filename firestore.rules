rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Alerts Collection ---
    match /alerts/{alertId} {
      function isValidAlert(data) {
        return data.keys().hasAll(['userId', 'symbol', 'condition', 'targetPrice', 'createdAt', 'triggered']) &&
               data.keys().size() <= 7 && // size check allow for optional fields if needed, but blueprint has 6
               data.userId == request.auth.uid &&
               data.symbol is string && data.symbol.size() <= 50 &&
               data.condition in ['above', 'below'] &&
               data.targetPrice is number &&
               data.triggered is bool;
      }

      allow create: if isSignedIn() && isValidAlert(incoming()) && incoming().createdAt == request.time && incoming().triggered == false;
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow update: if isOwner(existing().userId) && 
        (incoming().diff(existing()).affectedKeys().hasOnly(['triggered', 'triggeredAt']) && 
         incoming().triggered == true && 
         incoming().triggeredAt == request.time);

      allow delete: if isOwner(existing().userId);
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /private/settings {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
